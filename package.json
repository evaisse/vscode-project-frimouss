{
  "name": "vscode-project-frimouss",
  "displayName": "Project Frimouss",
  "description": "Display a nice avatar/badge for the current project based on its directory name",
  "version": "0.0.1",
  "publisher": "evaisse",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Other",
    "Visualization"
  ],
  "keywords": [
    "avatar",
    "project",
    "identifier",
    "status bar",
    "workspace",
    "theme"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/evaisse/vscode-project-frimouss.git"
  },
  "bugs": {
    "url": "https://github.com/evaisse/vscode-project-frimouss/issues"
  },
  "homepage": "https://github.com/evaisse/vscode-project-frimouss#readme",
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "projectFrimouss.showAvatar",
        "title": "Show Project Avatar",
        "category": "Project Frimouss"
      },
      {
        "command": "projectFrimouss.refreshAvatar",
        "title": "Refresh Project Avatar",
        "category": "Project Frimouss"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/vscode": "^1.74.0",
    "@types/node": "16.x",
    "typescript": "^4.9.4"
  },
  "dependencies": {}
}